          "rawSql": "SELECT\n  DATE_TRUNC('month', s.sale_date) AS time,\n  st.region AS metric,\n  SUM(s.total_amount) AS value\nFROM sales_fact s\nJOIN dim_store st ON s.store_id = st.store_id\nJOIN dim_product p ON s.product_id = p.product_id\nWHERE st.region IN (${region:sqlstring}) AND p.category IN (${category:sqlstring})\nGROUP BY 1, 2\nORDER BY 1, 2;",
