      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "retail-postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  st.store_name,\n  st.region,\n  SUM(s.total_amount) AS revenue,\n  SUM(s.profit) AS profit,\n  ROUND((SUM(s.profit) / NULLIF(SUM(s.total_amount), 0))::numeric * 100, 2) AS profit_margin_pct\nFROM sales_fact s\nJOIN dim_store st ON s.store_id = st.store_id\nJOIN dim_product p ON s.product_id = p.product_id\nWHERE st.region IN (${region:sqlstring}) AND p.category IN (${category:sqlstring})\nGROUP BY st.store_name, st.region\nORDER BY profit DESC;",
          "refId": "A"
        }
      ],
      "title": "Store Profitability",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "retail-postgres"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 8,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "retail-postgres"
          },
          "format": "table",
          "rawSql": "WITH customer_metrics AS (\n  SELECT\n    s.customer_id,\n    (SELECT MAX(sale_date) FROM sales_fact) - MAX(s.sale_date) AS recency_days,\n    COUNT(*) AS frequency,\n    SUM(s.total_amount) AS monetary\n  FROM sales_fact s\n  JOIN dim_store st ON s.store_id = st.store_id\n  JOIN dim_product p ON s.product_id = p.product_id\n  WHERE st.region IN (${region:sqlstring}) AND p.category IN (${category:sqlstring})\n  GROUP BY s.customer_id\n), rfm_scores AS (\n  SELECT\n    customer_id,\n    recency_days,\n    frequency,\n    monetary,\n    NTILE(5) OVER (ORDER BY recency_days DESC) AS r_score,\n    NTILE(5) OVER (ORDER BY frequency ASC) AS f_score,\n    NTILE(5) OVER (ORDER BY monetary ASC) AS m_score\n  FROM customer_metrics\n)\nSELECT\n  c.customer_id,\n  c.first_name || ' ' || c.last_name AS customer_name,\n  r.recency_days,\n  r.frequency,\n  r.monetary,\n  CASE\n    WHEN r.r_score >= 4 AND r.f_score >= 4 AND r.m_score >= 4 THEN 'Champion'\n    WHEN r.r_score >= 3 AND r.f_score >= 3 AND r.m_score >= 3 THEN 'Loyal'\n    WHEN r.r_score >= 4 AND r.f_score <= 2 AND r.m_score <= 2 THEN 'New'\n    WHEN r.r_score <= 2 AND r.f_score >= 3 AND r.m_score >= 3 THEN 'At Risk'\n    ELSE 'Others'\n  END AS segment\nFROM rfm_scores r\nJOIN dim_customer c ON r.customer_id = c.customer_id\nORDER BY r.monetary DESC\nLIMIT 25;",
          "refId": "A"
        }
      ],
      "title": "Top Customer Segments",
      "type": "table"
    }
